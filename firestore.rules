rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Game uses these collections (keep current behavior) ---
    match /tournaments/{docId} {
      allow read, write: if true;
    }
    match /entries/{docId} {
      allow read, write: if true;
    }
    match /matches/{docId} {
      allow read, write: if true;
    }
    match /logs/{docId} {
      allow read, write: if true;
    }
    match /history/{docId} {
      allow read, write: if true;
    }
    match /cooldowns/{docId} {
      allow read, write: if true;
    }
    match /action_logs/{docId} {
      allow read, write: if true;
    }
    match /spam_alerts/{docId} {
      allow read, write: if true;
    }
    // --- Deny all other collections ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
